# Clave para entrar a la paginita
UNLOCK_PASSWORD=botella

# Secreto para firmar la cookie de sesión (poné un string random largo)
AUTH_SECRET=cambiame-por-un-string-random-de-32-chars-o-mas

# Token de Vercel Blob (se setea automático al linkear el store en Vercel)
BLOB_READ_WRITE_TOKEN=

# Avisos por mail (Gmail + Nodemailer). Si no se setean, simplemente no manda mails.
GMAIL_USER=tucuenta@gmail.com
GMAIL_APP_PASSWORD=la-app-password-de-16-letras-sin-espacios
MARC_EMAIL=mail-de-marc@ejemplo.com
CELE_EMAIL=mail-de-cele@ejemplo.com

# URL del sitio para el botón del mail (opcional, default https://lightblue.vercel.app)
SITE_URL=https://lightblue.vercel.app
